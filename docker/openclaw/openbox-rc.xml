<?xml version="1.0" encoding="UTF-8"?>
<openbox_config xmlns="http://openbox.org/3.4/rc">
  <!-- Minimal OpenBox config for AI agent desktop -->
  <resistance><strength>10</strength><screen_edge_strength>20</screen_edge_strength></resistance>
  <focus><focusNew>yes</focusNew><followMouse>no</followMouse><raiseOnFocus>no</raiseOnFocus></focus>
  <placement><policy>Smart</policy><center>yes</center></placement>
  <theme><name>Clearlooks</name><titleLayout>NLIMC</titleLayout>
    <font place="ActiveWindow"><name>sans</name><size>9</size><weight>bold</weight></font>
    <font place="InactiveWindow"><name>sans</name><size>9</size><weight>bold</weight></font>
  </theme>
  <desktops><number>1</number></desktops>
  <!-- No keyboard/mouse bindings — agent controls programmatically -->
  <keyboard/>
  <mouse/>
  <applications>
    <!-- Maximize Chrome/Chromium windows by default -->
    <application class="Google-chrome" type="normal">
      <maximized>yes</maximized>
      <decor>no</decor>
    </application>
    <application class="Chromium-browser" type="normal">
      <maximized>yes</maximized>
      <decor>no</decor>
    </application>
  </applications>
</openbox_config>
